NODE_ENV=production
APP_NAME=Torre de Controle
PORT=3333
FRONTEND_PORT=3345
FRONTEND_HTTPS_PORT=3344
APP_PUBLIC_URL=http://127.0.0.1:3344
BACKEND_TARGET_URL=http://127.0.0.1:3333
FRONTEND_TLS_PFX_PATH=
FRONTEND_TLS_PFX_PASSWORD=
TLS_CERT_PATH=
TLS_KEY_PATH=

JWT_SECRET_KEY=troque-por-uma-chave-com-32-caracteres-ou-mais
AUTH_STATIC_PASSWORD=troque-por-uma-senha-forte
ALLOW_WEAK_AUTH_STATIC_PASSWORD=false
LOG_LEVEL=info

# WinThor / Oracle
ORACLE_USER=
ORACLE_PASSWORD=
ORACLE_CONNECT_STRING=
# ORACLE_HOST=
# ORACLE_PORT=1521
# ORACLE_SERVICE_NAME=
ORACLE_POOL_MIN=1
ORACLE_POOL_MAX=10
ORACLE_POOL_INCREMENT=1
ORACLE_POOL_ALIAS=sgqPool
ORACLE_STMT_CACHE_SIZE=30
ORACLE_QUEUE_TIMEOUT_MS=5000

# Integração REDE
REDE_BASE_URL=
REDE_AUTH_PATH=/oauth2/token
REDE_SALES_PATH=/merchant-statement/v2/sales
REDE_PAYMENTS_PATH=/merchant-statement/v1/payments
REDE_CLIENT_ID=
REDE_CLIENT_SECRET=
REDE_PARENT_MERCHANT_ID=
REDE_PARENT_COMPANY_NUMBER=
REDE_SUBSIDIARIES=
REDE_PAGE_SIZE=100
REDE_TIMEOUT_MS=15000
REDE_RETRY_ATTEMPTS=3
REDE_RETRY_BASE_DELAY_MS=400
REDE_CHARGEBACK_CLIENT_ID=
REDE_CHARGEBACK_CLIENT_SECRET=
REDE_CHARGEBACK_DEFAULT_MERCHANT_ID=
REDE_CHARGEBACK_NOTIFICATIONS_PATH=/chargeback/v2/notifications
REDE_CHARGEBACK_SOLICITATIONS_PATH=/chargeback/v2/solicitations
REDE_CHARGEBACK_HISTORY_PATH=/chargeback/v2/history
REDE_CHARGEBACK_TIMEOUT_MS=15000
REDE_CHARGEBACK_RETRY_ATTEMPTS=3
REDE_CHARGEBACK_RETRY_BASE_DELAY_MS=400

# IA e automação
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT_MS=45000
OPENAI_TEMPERATURE=0.2

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_SECURE=false
SMTP_TIMEOUT_MS=15000
SMTP_RETRY_ATTEMPTS=3
RECONAI_OPERADORA_EMAIL=
RECONAI_MANAGER_EMAIL=
AUTOMATION_HIGH_VALUE_THRESHOLD=10000
AUTOMATION_ESCALATION_DAYS=7

UPLOAD_MAX_FILES=10
UPLOAD_MAX_FILE_SIZE_MB=25
